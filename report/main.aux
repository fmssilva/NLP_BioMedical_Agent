\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Tuning summary: baseline vs.\ tuned NDCG@100 for every model (5-fold CV on 32 train topics). Encoder selection (MedCPT) yields the largest gain ($\Delta $NDCG@100=+0.0837); LM-Dir correction ($\mu $=100) yields the second-largest (+0.0201).}}{11}{figure.2}\protected@file@percent }
\newlabel{fig:tuning_summary}{{2}{11}{Tuning summary: baseline vs.\ tuned NDCG@100 for every model (5-fold CV on 32 train topics). Encoder selection (MedCPT) yields the largest gain ($\Delta $NDCG@100=+0.0837); LM-Dir correction ($\mu $=100) yields the second-largest (+0.0201)}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces BM25 $k_1$/$b$ sweep — mean CV NDCG@100. Winner: $k_1$=1.5, $b$=1.0.}}{11}{figure.3}\protected@file@percent }
