\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces LM-Dir $\mu $ sweep — mean CV NDCG@100. Default $\mu $=2000 drastically under-performs; winner is $\mu $=100.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:lmdir_sweep}{{4}{11}{LM-Dir $\mu $ sweep — mean CV NDCG@100. Default $\mu $=2000 drastically under-performs; winner is $\mu $=100}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces LM-JM $\lambda $ sweep — NDCG@100 plateaus at $\lambda $=0.7; already the default, no change needed.}}{11}{figure.5}\protected@file@percent }
\newlabel{fig:lmjm_sweep}{{5}{11}{LM-JM $\lambda $ sweep — NDCG@100 plateaus at $\lambda $=0.7; already the default, no change needed}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Encoder comparison — NDCG@100 on 32 train topics. MedCPT dominates (+0.0837 over msmarco baseline).}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:encoder_sweep}{{6}{11}{Encoder comparison — NDCG@100 on 32 train topics. MedCPT dominates (+0.0837 over msmarco baseline)}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces RRF pair sweep — 8 strategy pairs × 3 $k$ values, 5-fold CV. Lexical pairs (BM25+LM-Dir) outperform KNN fusions at the rank-level; native hybrid fusion (Phase~2) is the recommended approach for BM25+KNN.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:rrf_sweep}{{7}{12}{RRF pair sweep — 8 strategy pairs × 3 $k$ values, 5-fold CV. Lexical pairs (BM25+LM-Dir) outperform KNN fusions at the rank-level; native hybrid fusion (Phase~2) is the recommended approach for BM25+KNN}{figure.7}{}}
