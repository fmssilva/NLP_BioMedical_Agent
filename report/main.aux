\@writefile{toc}{\contentsline {subsubsection}{Per-Topic Analysis}{13}{section*.28}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Precision-Recall Analysis (MAP)}{13}{section*.29}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Per-topic PR curves for KNN(MedCPT) on all 33 test topics. Green = best topic (170 — isoniazid hepatotoxicity, AP=0.8961); red = worst topic (140 — spontaneous hand fractures, AP=0.1168); orange = median topic (120 — causes of facial numbness, AP=0.6277). Gray curves = remaining 30 topics. Dashed navy = mean AP (MAP=0.6143). Wide spread indicates high sensitivity to topic vocabulary.}}{14}{figure.10}\protected@file@percent }
\newlabel{fig:individual_pr}{{10}{14}{Per-topic PR curves for KNN(MedCPT) on all 33 test topics. Green = best topic (170 — isoniazid hepatotoxicity, AP=0.8961); red = worst topic (140 — spontaneous hand fractures, AP=0.1168); orange = median topic (120 — causes of facial numbness, AP=0.6277). Gray curves = remaining 30 topics. Dashed navy = mean AP (MAP=0.6143). Wide spread indicates high sensitivity to topic vocabulary}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Per-topic AP distribution across all strategies (test set, 33 topics). RRF (tuned) achieves the highest median AP and the least variance. Wide IQR reflects inherent topic-difficulty spread. Outliers below the whisker correspond to hard topics (AP$<$0.3).}}{14}{figure.11}\protected@file@percent }
\newlabel{fig:ap_boxplot}{{11}{14}{Per-topic AP distribution across all strategies (test set, 33 topics). RRF (tuned) achieves the highest median AP and the least variance. Wide IQR reflects inherent topic-difficulty spread. Outliers below the whisker correspond to hard topics (AP$<$0.3)}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Mean interpolated PR curves for all strategies on the 33-query test set (left) with MAP/MRR bar chart (right). RRF (tuned) and KNN (MedCPT) dominate across the full recall range. LM variants show steeper early-recall drops.}}{15}{figure.12}\protected@file@percent }
\newlabel{fig:pr_curves}{{12}{15}{Mean interpolated PR curves for all strategies on the 33-query test set (left) with MAP/MRR bar chart (right). RRF (tuned) and KNN (MedCPT) dominate across the full recall range. LM variants show steeper early-recall drops}{figure.12}{}}
