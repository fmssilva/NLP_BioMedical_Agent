\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Corpus document length distribution (word count). Mean=150 words; right-skewed with a long tail up to 964 words. Motivates $b$=1.0 length normalisation in BM25 and low $\mu $ in LM-Dir.}}{16}{figure.15}\protected@file@percent }
\newlabel{fig:doc_lengths}{{15}{16}{Corpus document length distribution (word count). Mean=150 words; right-skewed with a long tail up to 964 words. Motivates $b$=1.0 length normalisation in BM25 and low $\mu $ in LM-Dir}{figure.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Reciprocal rank distribution for each strategy (test set). MedCPT and RRF return the first relevant document much earlier (higher RR) than lexical models.}}{16}{figure.16}\protected@file@percent }
