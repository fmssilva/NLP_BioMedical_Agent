\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces All 5 metrics for each strategy, baseline (light) vs tuned (dark), on the 33-query test set. MedCPT KNN shows the largest improvement across all metrics; BM25 tuning effect is negligible.}}{12}{figure.8}\protected@file@percent }
\newlabel{fig:baseline_vs_tuned}{{8}{12}{All 5 metrics for each strategy, baseline (light) vs tuned (dark), on the 33-query test set. MedCPT KNN shows the largest improvement across all metrics; BM25 tuning effect is negligible}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Tuning gain on the test set ($\Delta $NDCG@100 and $\Delta $MAP, tuned $-$ baseline). KNN and RRF gain significantly; BM25 tuning yields no measurable gain ($\Delta \approx -0.0009$).}}{13}{figure.9}\protected@file@percent }
\newlabel{fig:tuning_gain}{{9}{13}{Tuning gain on the test set ($\Delta $NDCG@100 and $\Delta $MAP, tuned $-$ baseline). KNN and RRF gain significantly; BM25 tuning yields no measurable gain ($\Delta \approx -0.0009$)}{figure.9}{}}
\@writefile{toc}{\contentsline {subsubsection}{Precision-Recall Analysis}{13}{section*.17}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Mean interpolated PR curves for all strategies on the 33-query test set (left) with MAP/MRR bar chart (right). RRF (tuned) and KNN (MedCPT) dominate across the full recall range. LM variants show steeper early-recall drops.}}{13}{figure.10}\protected@file@percent }
\newlabel{fig:pr_curves}{{10}{13}{Mean interpolated PR curves for all strategies on the 33-query test set (left) with MAP/MRR bar chart (right). RRF (tuned) and KNN (MedCPT) dominate across the full recall range. LM variants show steeper early-recall drops}{figure.10}{}}
\@writefile{toc}{\contentsline {subsubsection}{Per-Topic AP Distribution}{13}{section*.18}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces PR curve interpretation guide (top row: perfect / random / ideal retriever; bottom row: fair / moderate / our actual test results). Our strategies fall in the \emph  {moderate-to-good} range — well above random, with RRF approaching the ideal curve shape.}}{14}{figure.11}\protected@file@percent }
\newlabel{fig:pr_interp}{{11}{14}{PR curve interpretation guide (top row: perfect / random / ideal retriever; bottom row: fair / moderate / our actual test results). Our strategies fall in the \emph {moderate-to-good} range — well above random, with RRF approaching the ideal curve shape}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Per-topic PR curves for RRF (tuned) on all 33 test topics. Green = best topic (170, AP=0.9289); red = worst topic (156, AP=0.1862); orange = median topic (138, AP=0.6572). Gray curves = remaining 30 topics. Dashed navy = mean AP (MAP=0.6262). Wide spread indicates high sensitivity to topic vocabulary.}}{14}{figure.12}\protected@file@percent }
\newlabel{fig:individual_pr}{{12}{14}{Per-topic PR curves for RRF (tuned) on all 33 test topics. Green = best topic (170, AP=0.9289); red = worst topic (156, AP=0.1862); orange = median topic (138, AP=0.6572). Gray curves = remaining 30 topics. Dashed navy = mean AP (MAP=0.6262). Wide spread indicates high sensitivity to topic vocabulary}{figure.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Per-topic AP distribution across all strategies (test set, 33 topics). RRF (tuned) achieves the highest median AP and the least variance. Wide IQR reflects inherent topic-difficulty spread. Outliers below the whisker correspond to hard topics (AP$<$0.3).}}{15}{figure.13}\protected@file@percent }
\newlabel{fig:ap_boxplot}{{13}{15}{Per-topic AP distribution across all strategies (test set, 33 topics). RRF (tuned) achieves the highest median AP and the least variance. Wide IQR reflects inherent topic-difficulty spread. Outliers below the whisker correspond to hard topics (AP$<$0.3)}{figure.13}{}}
