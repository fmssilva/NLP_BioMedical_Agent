\newlabel{fig:confusion_p10}{{17}{17}{Confusion matrix at P@10 — relevant vs.\ retrieved in the top-10 results, per strategy. RRF (tuned) achieves the highest true positive rate in the top-10 positions}{figure.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Query length (token count) vs.\ AP per topic for RRF (tuned). Longer queries generally produce higher AP, consistent with the \texttt  {topic+question} ablation result.}}{17}{figure.18}\protected@file@percent }
\newlabel{fig:query_len_ap}{{18}{17}{Query length (token count) vs.\ AP per topic for RRF (tuned). Longer queries generally produce higher AP, consistent with the \texttt {topic+question} ablation result}{figure.18}{}}
